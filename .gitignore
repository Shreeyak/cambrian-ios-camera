.remember
.xcodebuildmcp/
Gemfile.lock
docs/tmp/

# xcode-build-server output (machine-specific DerivedData path)
buildServer.json

# SwiftPM build artifacts
.build/
.swiftpm/

# Root-level Package.resolved — library convention (consumers re-resolve).
# Xcode-side Package.resolved (under ios_example_app/.../xcshareddata/swiftpm/)
# is NOT ignored — it pins the app's deps and should be committed.
/Package.resolved

# Persistent xcodebuild logs from scripts/{build,test}-summary.sh
.build-logs/

# Xcode user data
**/xcuserdata/

# Claude Code session state
.claude/scheduled_tasks.lock
.claude/todos/
.claude/projects/
.claude/worktrees/

# Upstream symlinks (machine-specific; recreated per-checkout)
# implementation/

# Throwaway experiment trees (live until results recorded under measurements/)
experiments/
