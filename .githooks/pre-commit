#!/usr/bin/env bash
# pre-commit — keep Swift sources tidy and CONTRACTS.md in sync with HEAD.
#
# This hook runs on staged changes only. Two gates:
#   1. swift-format --lint --strict on any staged .swift files under
#      CameraKit/Sources/. This is the authoritative style gate.
#   2. Regenerate CameraKit/CONTRACTS.md if any CameraKit/Sources file changed;
#      stage the regenerated CONTRACTS.md so it's part of the commit.
#
# SwiftLint is intentionally NOT run here. CameraKit/Sources carries deliberate
# patterns SwiftLint flags as errors (test-seam identifiers like
# _emitErrorForTest, the large CameraEngine actor body), so gating on it would
# block every legitimate commit. Run `swiftlint lint --config .swiftlint.yml`
# manually when you want its advice (see CLAUDE.md §6). swift-format --strict
# is the real gate.
#
# Any failure aborts the commit. To bypass for a genuine emergency:
#   git commit --no-verify   (DO NOT use casually — plan calls this out)
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

STAGED_SWIFT=$(git diff --cached --name-only --diff-filter=ACM | grep -E '^CameraKit/Sources/.*\.swift$' || true)

if [[ -n "$STAGED_SWIFT" ]]; then
  if command -v swift-format >/dev/null 2>&1; then
    echo "→ swift-format lint"
    echo "$STAGED_SWIFT" | xargs swift-format lint --strict || {
      echo "✖ swift-format found issues. Run: swift-format -i \$FILE to fix." >&2
      exit 1
    }
  fi

  if [[ -x scripts/regen-contracts.sh ]]; then
    echo "→ regenerating CameraKit/CONTRACTS.md"
    scripts/regen-contracts.sh >/dev/null
    git add CameraKit/CONTRACTS.md
  fi
fi

exit 0
