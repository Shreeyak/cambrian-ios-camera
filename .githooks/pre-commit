#!/usr/bin/env bash
# pre-commit — keep Swift sources tidy and CONTRACTS.md in sync with HEAD.
#
# This hook runs on staged changes only. Three gates:
#   1. swift-format --lint on any staged .swift files under CameraKit/Sources/.
#   2. SwiftLint on the same files, if .swiftlint.yml exists.
#   3. Regenerate CameraKit/CONTRACTS.md if any CameraKit/Sources file changed;
#      stage the regenerated CONTRACTS.md so it's part of the commit.
#
# Any failure aborts the commit. To bypass for a genuine emergency:
#   git commit --no-verify   (DO NOT use casually — plan calls this out)
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

STAGED_SWIFT=$(git diff --cached --name-only --diff-filter=ACM | grep -E '^CameraKit/Sources/.*\.swift$' || true)

if [[ -n "$STAGED_SWIFT" ]]; then
  if command -v swift-format >/dev/null 2>&1; then
    echo "→ swift-format lint"
    echo "$STAGED_SWIFT" | xargs swift-format lint --strict || {
      echo "✖ swift-format found issues. Run: swift-format -i \$FILE to fix." >&2
      exit 1
    }
  fi

  # Prefer arm64-native SwiftLint (/opt/homebrew) over x86_64 Rosetta (/usr/local)
  # to avoid sourcekitd framework load crash on Apple Silicon with Xcode-beta.
  SWIFTLINT_BIN=""
  if [[ -x /opt/homebrew/bin/swiftlint ]]; then
    SWIFTLINT_BIN=/opt/homebrew/bin/swiftlint
  elif command -v swiftlint >/dev/null 2>&1; then
    SWIFTLINT_BIN=$(command -v swiftlint)
  fi

  if [[ -n "$SWIFTLINT_BIN" ]] && [[ -f .swiftlint.yml ]]; then
    echo "→ SwiftLint"
    "$SWIFTLINT_BIN" lint --quiet --config .swiftlint.yml --use-script-input-files <<<"$STAGED_SWIFT" || {
      # SwiftLint exit code 2 = warnings only; keep 1 as hard fail.
      STATUS=$?
      if (( STATUS > 1 )); then
        echo "✖ SwiftLint errors." >&2
        exit 1
      fi
    }
  fi


  if [[ -x scripts/regen-contracts.sh ]]; then
    echo "→ regenerating CameraKit/CONTRACTS.md"
    scripts/regen-contracts.sh >/dev/null
    git add CameraKit/CONTRACTS.md
  fi
fi

exit 0
