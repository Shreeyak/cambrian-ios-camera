#!/bin/sh
# .githooks/pre-push
#
# Keep the camerakit-only synthetic branch in sync.
#
# Whenever a push to origin/main includes commits touching CameraKit/,
# regenerate the camerakit-only branch (CameraKit/ contents at root, history
# filtered) and force-push it to origin. This is the branch consumed by
# camera2_flutter_demo/packages/cambrian_camera via `git subtree pull`.
# See CLAUDE.md §10.
#
# One-time enable per clone:  git config core.hooksPath .githooks
# Skip on a one-off:           git push --no-verify

set -e

remote_name="$1"
[ "$remote_name" != "origin" ] && exit 0

# stdin format per git documentation:
#   <local_ref> SP <local_sha> SP <remote_ref> SP <remote_sha> LF
camerakit_changed=0
while read local_ref local_sha remote_ref remote_sha; do
    case "$remote_ref" in
        refs/heads/main) ;;
        *) continue ;;
    esac

    if [ "$remote_sha" = "0000000000000000000000000000000000000000" ]; then
        # New branch on remote — use the full reachable history
        range="$local_sha"
    else
        range="$remote_sha..$local_sha"
    fi

    if git log --name-only "$range" 2>/dev/null | grep -q '^CameraKit/'; then
        camerakit_changed=1
        break
    fi
done

[ "$camerakit_changed" = "0" ] && exit 0

echo "→ CameraKit/ changes detected; updating camerakit-only branch"
# Compute the split commit and push it straight to the remote ref. Pushing by
# SHA (rather than `git subtree split -b camerakit-only`) is idempotent: the
# `-b` form fails once a local camerakit-only branch exists, which it will after
# the first run. `-q` suppresses the per-commit progress flood on every push.
split_sha=$(git subtree split --prefix=CameraKit -q)
git push --force origin "${split_sha}:refs/heads/camerakit-only"
echo "✓ camerakit-only branch updated and pushed ($split_sha)"
